{
  "name": "cyber-place-panel-desktop",
  "version": "1.0.40-staging.4",
  "private": true,
  "main": "electron/dist/main.js",
  "description": "Cyber Place staff panel — gaming-venue management for admin, owners and managers (bookings, sessions, tournaments, billing).",
  "homepage": "https://cyberplace.pro",
  "license": "UNLICENSED",
  "author": {
    "name": "Cyber Place",
    "email": "support@cyberplace.pro",
    "url": "https://cyberplace.pro"
  },
  "scripts": {
    "dev": "vite",
    "build:web": "tsc -p tsconfig.app.json && vite build",
    "build:web:staging": "tsc -p tsconfig.app.json && vite build --mode staging",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:web && npm run build:electron",
    "build:staging": "npm run build:web:staging && npm run build:electron",
    "preview": "vite preview",
    "electron:dev": "npm run build:electron && ELECTRON_DEV_URL=http://localhost:5173 electron electron/dist/main.js",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:linux:staging": "npm run build:staging && electron-builder --linux --config electron-builder.staging.json",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:staging": "npm run build:staging && electron-builder --win --config electron-builder.staging.json",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "jsqr": "^1.4.0",
    "laravel-echo": "^2.3.4",
    "leaflet": "^1.9.4",
    "pusher-js": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.5",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  }
}
