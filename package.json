{
  "name": "cyber-place-panel-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/dist/main.js",
  "author": "Developer <dev@develop.com>",
  "scripts": {
    "dev": "vite",
    "build:web": "tsc -p tsconfig.app.json && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:web && npm run build:electron",
    "preview": "vite preview",
    "electron:dev": "ELECTRON_DEV_URL=http://localhost:5173 npm run build:electron && electron electron/dist/main.js",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "jsqr": "^1.4.0",
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.5",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  }
}
